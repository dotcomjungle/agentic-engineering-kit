# Client environment for the agent-sdk / claude-api harnesses.
# Copy to .env and fill in real values. .env is gitignored.
# Never put secrets here — Vite inlines VITE_-prefixed variables into the build.

# Optional: API base URL when client and server are not same-origin in production.
# In development, the Vite proxy maps /api → http://localhost:8000, so leave unset.
# VITE_API_BASE_URL=https://api.example.com

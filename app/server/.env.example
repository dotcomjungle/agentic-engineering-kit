# Server environment for the agent-sdk / claude-api engines.
# Copy to .env and fill in real values. .env is gitignored.

# Anthropic API key — read by the Anthropic SDK under this exact name.
ANTHROPIC_API_KEY=<your-key-here>

# Postgres connection string for SQLAlchemy async + asyncpg.
DATABASE_URL=postgresql+asyncpg://localhost:5432/app

# Application settings (pydantic-settings) — use your project's prefix.
# Examples (replace APP_ with your prefix, e.g. MYAPP_):
# APP_LOG_LEVEL=info
# APP_DEBUG=false
